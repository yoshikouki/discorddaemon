{
  "name": "discorddaemon",
  "version": "0.1.0",
  "description": "Discord daemon with per-channel hooks. UNIX philosophy for Discord bots.",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "ddd": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts start",
    "dev": "bun run --watch src/index.ts start --foreground",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "ultracite check",
    "docs": "bun run scripts/docs.ts",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "discord.js": "^14.25.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7",
    "ultracite": "7.3.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT"
}
