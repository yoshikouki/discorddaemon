{
  "name": "discorddaemon",
  "version": "0.1.0",
  "description": "Discord daemon with per-channel hooks. UNIX philosophy for Discord bots.",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "ddd": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts start",
    "dev": "bun run --watch src/index.ts start",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "discord.js": "^14.18.0",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "license": "MIT",
  "trustedDependencies": [
    "@biomejs/biome"
  ]
}
